{
  "name": "component-testing-compare",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "run-await-run 'node --watch server/main.ts' :3000 vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "fmt": "oxfmt",
    "test:run": "run-await-run 'node server/main.ts' :3000 'vitest run'",
    "test": "vitest",
    "test-ct": "playwright test -c playwright-ct.config.ts --ui"
  },
  "dependencies": {
    "@ant-design/icons": "~6.1.0",
    "@neoconfetti/react": "^1.0.0",
    "@tanstack/react-query": "^5.95.2",
    "antd": "^6.3.4",
    "h3": "2.0.1-rc.19",
    "ohash": "^2.0.11",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "valtio": "^2.3.1"
  },
  "devDependencies": {
    "@playwright/experimental-ct-react": "^1.59.1",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser-playwright": "^4.1.2",
    "oxfmt": "^0.41.0",
    "run-await-run": "^1.0.1",
    "typescript": "5.9.3",
    "vite": "8.0.1",
    "vitest": "^4.1.2",
    "vitest-browser-react": "^2.1.0"
  },
  "nano-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  }
}

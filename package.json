{
  "name": "component-testing-compare",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "run-await-run 'node --watch server/main.ts' :3000 vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "fmt": "oxfmt",
    "vitest:ui": "vitest",
    "vitest:run": "run-await-run 'node server/main.ts' :3000 'vitest run --browser.headless'",
    "playwright:ui": "playwright test --ui",
    "playwright:run": "run-await-run 'node server/main.ts' :3000 'playwright test'",
    "cypress:ui": "cypress open",
    "cypress:run": "run-await-run 'node server/main.ts' :3000 'cypress run --component'"
  },
  "dependencies": {
    "@ant-design/icons": "~6.1.1",
    "@neoconfetti/react": "^1.0.0",
    "@tanstack/react-query": "^5.100.1",
    "antd": "^6.3.6",
    "clsx": "^2.1.1",
    "h3": "2.0.1-rc.20",
    "ohash": "^2.0.11",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "valtio": "^2.3.1"
  },
  "devDependencies": {
    "@playwright/experimental-ct-react": "^1.59.1",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser-playwright": "^4.1.5",
    "cypress": "^15.14.1",
    "oxfmt": "^0.46.0",
    "run-await-run": "^1.0.1",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vitest": "^4.1.5",
    "vitest-browser-react": "^2.2.0"
  },
  "nano-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  }
}
